<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!--
    UpgradeCode must stay stable across releases so newer MSIs can upgrade older ones.
    ProductVersion comes from MSBuild (DefineConstants / build-msi.ps1).
    Language / UI strings come from Loc/*.wxl (one MSI per culture).
  -->
  <Package Name="DisplayForge"
           Manufacturer="$(Publisher)"
           Version="$(ProductVersion)"
           UpgradeCode="AB999BB1-FADA-4BE0-8EA6-F1054138E711"
           Scope="perMachine"
           Language="!(loc.PackageLanguage)">

    <SummaryInformation Description="!(loc.SummaryDescription)"
                        Manufacturer="$(Publisher)" />

    <MajorUpgrade DowngradeErrorMessage="!(loc.DowngradeError)"
                  Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="AppIcon" SourceFile="$(AppIcon)" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <!--
      Secure so the elevated execute sequence sees the UI checkbox value.
      Default "1" = enabled (checked). Silent: msiexec /i ... START_WITH_WINDOWS=0
    -->
    <Property Id="START_WITH_WINDOWS" Secure="yes" Value="1" />

    <Feature Id="ProductFeature" Title="DisplayForge" Level="1">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="StartupRunKey" />
    </Feature>

    <!-- Custom set: WixUI_InstallDir + OptionsDlg (startup checkbox). -->
    <ui:WixUI Id="WixUI_InstallDir_Options" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DisplayForge" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="DisplayForge" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />
  </Package>

  <Fragment>
    <!-- Harvest publish output (self-contained win-x64). -->
    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <Files Include="!(bindpath.Publish)**">
        <Exclude Files="!(bindpath.Publish)**\*.pdb" />
        <Exclude Files="!(bindpath.Publish)**\*.xml" />
      </Files>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <Component Id="StartMenuShortcut"
               Directory="ApplicationProgramsFolder"
               Guid="4F2B4C7E-81BA-433F-B9D8-52F75159571F">
      <Shortcut Id="StartMenuShortcutLink"
                Name="DisplayForge"
                Description="!(loc.ShortcutDescription)"
                Target="[INSTALLFOLDER]DisplayForge.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\DisplayForge"
                     Name="StartMenuShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcut"
               Directory="DesktopFolder"
               Guid="B1C2D3E4-F5A6-4789-8B0C-1D2E3F4A5B6C">
      <Shortcut Id="DesktopShortcutLink"
                Name="DisplayForge"
                Description="!(loc.ShortcutDescription)"
                Target="[INSTALLFOLDER]DisplayForge.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon" />
      <RegistryValue Root="HKCU"
                     Key="Software\DisplayForge"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!--
      Optional autostart via HKMU Run (HKLM for per-machine install).
      Installed only when START_WITH_WINDOWS=1 (UI checkbox / property).
    -->
    <Component Id="StartupRunKey"
               Directory="INSTALLFOLDER"
               Guid="E8A7C6B5-4D3E-4F2A-9C1B-0A9F8E7D6C5B"
               Condition="START_WITH_WINDOWS=&quot;1&quot;">
      <RegistryValue Root="HKMU"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="DisplayForge"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]DisplayForge.exe&quot;"
                     KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>

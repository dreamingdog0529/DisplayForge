#!/usr/bin/env bash
# Local Conventional Commits check (same rules as CI).
# Enable once per clone:  git config core.hooksPath .githooks
#   or:  pwsh ./scripts/install-git-hooks.ps1

set -euo pipefail

msg_file=$1
if [[ ! -f "$msg_file" ]]; then
  echo "commit-msg: missing message file: $msg_file" >&2
  exit 1
fi

# First non-comment, non-empty line is the subject
subject=""
while IFS= read -r line || [[ -n "$line" ]]; do
  line=${line//$'\r'/}
  # Git commit template comments
  [[ "$line" =~ ^# ]] && continue
  [[ -z "${line// }" ]] && continue
  subject=$line
  break
done <"$msg_file"

root=$(git rev-parse --show-toplevel)
validator="$root/scripts/validate-commit-subject.sh"

if [[ ! -f "$validator" ]]; then
  echo "commit-msg: validator not found: $validator" >&2
  exit 1
fi

exec bash "$validator" "$subject"

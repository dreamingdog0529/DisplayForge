#!/usr/bin/env bash
# Fallback hooks when lefthook is not installed.
# Prefer: task setup  (installs lefthook)
# Or:     pwsh ./scripts/install-git-hooks.ps1

set -euo pipefail

msg_file=$1
subject=$(head -1 "$msg_file" | tr -d '\r')

# Skip merge commits (also when MERGE_HEAD exists)
if [[ -n "${GIT_DIR:-}" && -f "${GIT_DIR}/MERGE_HEAD" ]] || [[ -f "$(git rev-parse --git-path MERGE_HEAD 2>/dev/null || true)" ]]; then
  exit 0
fi
if [[ "$subject" =~ ^Merge\  ]]; then
  exit 0
fi

root=$(git rev-parse --show-toplevel)
if [[ -x "$root/scripts/validate-commit-subject.sh" ]] || [[ -f "$root/scripts/validate-commit-subject.sh" ]]; then
  bash "$root/scripts/validate-commit-subject.sh" "$subject"
else
  pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-zA-Z0-9._/-]+\))?(!)?: .+'
  if ! [[ "$subject" =~ $pattern ]]; then
    echo "Commit message is not Conventional Commits: $subject" >&2
    exit 1
  fi
fi

if ! grep -q "^Signed-off-by:" "$msg_file"; then
  echo "ERROR: Missing DCO sign-off. Use 'git commit -s'" >&2
  exit 1
fi

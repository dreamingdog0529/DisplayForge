# Auto-detect text files; normalize line endings on commit.
* text=auto

# Source and project files
*.cs     text diff=csharp
*.xaml   text
*.resx   text
*.csproj text
*.sln    text
*.props  text
*.targets text
*.wxs    text
*.wxl    text
*.wixproj text
*.ps1    text eol=crlf
*.cmd    text eol=crlf
*.bat    text eol=crlf
*.sh     text eol=lf
# Git hooks (no extension); must stay LF for bash on Windows
.githooks/** text eol=lf
*.md     text diff=markdown
*.json   text
*.yml    text
*.yaml   text
*.xml    text
*.config text
*.manifest text
*.rtf    text
*.svg    text
*.gitignore text
*.gitattributes text

# Binary assets
*.ico    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.bmp    binary
*.msi    binary
*.exe    binary
*.dll    binary
*.pdb    binary
*.wixpdb binary
*.zip    binary
